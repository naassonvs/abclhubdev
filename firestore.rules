rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Vendas: autenticados escrevem tudo; loja pode escrever sem login
    match /vendas/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        || (request.resource.data.tipo == 'loja'
            && request.resource.data.keys().hasAll(['tipo','total','forma_pagamento','status']));
    }

    // Estoque loja: loja pública pode subtrair; autenticados controlam tudo
    match /loja_estoque/{document=**} {
      allow read: if true;
      allow write: if request.auth != null
        || request.resource.data.keys().hasAll(['estoque','nome','atualizado_em']);
    }

    // Produtos Vendinha
    match /produtos_vendinha/{document=**} {
      allow read, write: if request.auth != null;
    }
    // Produtos Livraria
    match /produtos_livraria/{document=**} {
      allow read, write: if request.auth != null;
    }
    // Produtos Loja
    match /produtos_loja/{document=**} {
      allow read, write: if request.auth != null;
    }
    // Usuarios
    match /usuarios/{uid} {
      allow read, write: if request.auth != null;
    }
    // Configs
    match /configs/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── INSCRIÇÕES ─────────────────────────────────────────────
    // Admin (autenticado) cria livre (ex.: import CSV).
    // Formulário público só cria se o payload tiver a forma de uma inscrição real.
    match /inscricoes/{document=**} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        || ( request.resource.data.form_id is string
          && request.resource.data.respostas is map
          && request.resource.data.origem == 'formulario' );
      allow update, delete: if request.auth != null;
    }

    // ── ACAMPANTES ─────────────────────────────────────────────
    // Upsert público (form), mas validando a forma. Leitura/exclusão só autenticado.
    // (nome pode ser '' — telefone-only é válido; validamos TIPO, não tamanho.)
    match /acampantes/{document=**} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        || ( request.resource.data.nome is string
          && request.resource.data.dados is map );
      allow delete: if request.auth != null;
    }

    // Hinos / Cânticos
    match /canticos/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Financeiro
    match /financeiro_resumo/{document=**} {
      allow read, write: if request.auth != null;
    }
    // Tudo mais: leitura pública, escrita autenticada
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
